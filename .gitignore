# Python cache — never commit these
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor artifacts
.idea/
.vscode/
*.swp
*.swo
*~

# Data — raw session files stay local, only anonymized versions commit
datasets/worldmart/raw/
datasets/sessions/raw/

# Environment variables — never commit secrets
.env
.env.local
